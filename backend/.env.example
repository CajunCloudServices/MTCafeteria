PORT=3201
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mtc_cafeteria
JWT_SECRET=replace-with-a-strong-secret
USE_MOCK_DATA=true

# Optional: tie the shared operational session to a real users.id in Postgres
# mode so inserts that record a submitter/creator satisfy FK constraints.
# SHARED_SESSION_USER_ID=4
# SHARED_SESSION_EMAIL=manager@mtc.local
# SHARED_SESSION_ROLE=Student Manager

# Password required to edit jobs and tasks via the /api/task-admin endpoints.
# Defaults to "yoboss" if unset. Change this in production.
# TASK_EDITOR_PASSWORD=yoboss
# Optional path for mock-mode job/task edits to survive server restarts.
# The file is (re)written after every mutation. In Postgres mode this is
# unused because the database itself is the source of truth.
# TASK_EDITOR_PERSIST_PATH=./data/task_editor_overrides.json
