#!/usr/bin/env bash
set -euo pipefail

zero_sha="0000000000000000000000000000000000000000"
frontend_changed=0
bundle_changed=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "${local_sha:-}" ] || [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ -z "${remote_sha:-}" ] || [ "$remote_sha" = "$zero_sha" ]; then
    range=(git diff --name-only --root "$local_sha")
  else
    range=(git diff --name-only "$remote_sha..$local_sha")
  fi

  while IFS= read -r path; do
    case "$path" in
      frontend_flutter/*)
        frontend_changed=1
        ;;
      public/flutter-web/*)
        bundle_changed=1
        ;;
    esac
  done < <("${range[@]}")
done

if [ "$frontend_changed" -eq 1 ] && [ "$bundle_changed" -eq 0 ]; then
  cat >&2 <<'EOF'
Push blocked: this push includes changes under frontend_flutter/ but no committed updates under public/flutter-web/.

Before pushing, regenerate and commit the tracked Flutter web bundle:

  npm run flutter:web:sync
  git add frontend_flutter public/flutter-web
  git commit

Coolify deploys the committed files from main, so public/flutter-web must be refreshed whenever frontend_flutter changes.
EOF
  exit 1
fi
