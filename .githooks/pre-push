#!/usr/bin/env bash
set -euo pipefail

zero_sha="0000000000000000000000000000000000000000"
frontend_changed=0
bundle_changed=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "${local_sha:-}" ] || [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ -z "${remote_sha:-}" ] || [ "$remote_sha" = "$zero_sha" ]; then
    range=(git diff --name-only --root "$local_sha")
  else
    range=(git diff --name-only "$remote_sha..$local_sha")
  fi

  while IFS= read -r path; do
    case "$path" in
      frontend_flutter/*)
        frontend_changed=1
        ;;
      public/flutter-web/*)
        bundle_changed=1
        ;;
    esac
  done < <("${range[@]}")
done

if [ "$frontend_changed" -eq 1 ] && [ "$bundle_changed" -eq 0 ]; then
  cat >&2 <<'EOF'
Notice: this push includes frontend_flutter/ changes without committed updates under public/flutter-web/.

That is allowed now. Production rebuilds the Flutter bundle during CI/deploy, so the tracked copy under public/flutter-web is no longer the deployment source of truth.

If you want a local Docker/web smoke test before pushing, regenerate the bundle locally with:

  npm run flutter:web:sync
EOF
fi
