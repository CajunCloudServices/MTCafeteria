# Host ports for this app. Cloudflare Tunnel should target WEB_HOST_PORT.
WEB_HOST_PORT=3017
API_HOST_PORT=4013
DB_HOST_PORT=5436

# Public-facing app URL and backend allowlist.
APP_BASE_URL=https://cafeteria.example.com
CORS_ORIGINS=https://cafeteria.example.com

# App/runtime settings.
USE_MOCK_DATA=false
JWT_SECRET=replace-with-strong-secret

# Shared pilot session. When running against Postgres, set
# SHARED_SESSION_USER_ID to a real users.id so inserts that record a
# submitter/creator satisfy FK constraints. The seed creates
# `manager@mtc.local` as a Student Manager which is a good default.
# SHARED_SESSION_USER_ID=4
# SHARED_SESSION_EMAIL=manager@mtc.local
# SHARED_SESSION_ROLE=Student Manager

# Password required to edit jobs and tasks via the /api/task-admin endpoints.
# Defaults to "yoboss" if unset. Change this in production.
# TASK_EDITOR_PASSWORD=yoboss

# Postgres settings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=mtc_cafeteria
DATABASE_URL=postgresql://postgres:replace-with-strong-db-password@postgres:5432/mtc_cafeteria
