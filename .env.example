# Host ports for this app. Cloudflare Tunnel should target WEB_HOST_PORT.
# API and Postgres bind to localhost by default in docker-compose for safer exposure.
WEB_HOST_PORT=3017
API_HOST_PORT=4013
DB_HOST_PORT=5436

# Public-facing app URL and backend allowlist.
APP_BASE_URL=https://cafeteria.example.com
CORS_ORIGINS=https://cafeteria.example.com

# App/runtime settings.
USE_MOCK_DATA=false
JWT_SECRET=replace-with-strong-secret

# Password required to edit jobs and tasks via the /api/task-admin endpoints.
TASK_EDITOR_PASSWORD=replace-with-strong-task-editor-password

# Postgres settings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=mtc_cafeteria
DATABASE_URL=postgresql://postgres:replace-with-strong-db-password@postgres:5432/mtc_cafeteria

# Remote MTC chatbot proxy configuration.
CHATBOT_UPSTREAM_URL=http://100.84.218.4:18910
CHATBOT_API_TOKEN=replace-with-mtc-chatbot-token
CHATBOT_TIMEOUT_MS=65000
